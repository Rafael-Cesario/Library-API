generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Book {
  id          String @id @default(uuid())
  title       String
  pages       Int
  publishedAt String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authors Author[]

  @@map("books")
}

model Author {
  id   String @id @default(uuid())
  name String @unique
  bio  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books Book[]

  @@map("authors")
}
